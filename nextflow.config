import java.time.*
Date now = new Date()

// Require NF 24.10.x — the publish: block uses nextflow.preview.output
// which is a preview feature in 24.x (deprecated in 25.10+, absent in <24.04)
// Use manifest.nextflowVersion for declarative version guard
manifest {
    nextflowVersion = '>=24.10.0,<25.0.0'
}

nextflow.enable.moduleBinaries = true
process.cache = "lenient"

params {
    day = now.format("yyyMMdd")
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
    debug = false
    help = false

    strainfile = null
    group_qtl  = 1000
    ci_size    = 150
    nqtl       = null
    reps       = 2
    h2         = null
    effect     = null
    qtlloc     = null
    sthresh    = "BF"
    mito_name  = null
    simulate_qtlloc = null

    // Database integration — always writes Parquet DB alongside simulation results.
    // Default null: resolved at runtime in main.nf using workflow.outputDir
    db_output = null

    // Legacy assessment path — when true, runs the original R_GET_GCTA_INTERVALS +
    // R_ASSESS_SIMS chain alongside the DB-path analysis. Used for cross-validation.
    legacy_assess = false

    // Significance level for threshold calculation (Bonferroni/EIGEN)
    alpha = 0.05

    // Causal variant pool parameters — CV pool is separate from GWA marker SNP set.
    // cv_maf: null → each group uses its own strainfile ms_maf value
    // cv_ld: 0.8 → standard LD pruning threshold for CV pool
    cv_maf         = null
    cv_ld          = 0.8

    // Explicit output directory. When null, defaults to "Analysis_Results-{date}".
    // Override with --output_dir to produce stable, date-independent output paths.
    output_dir = null

    //
}

outputDir = params.output_dir ?: "Analysis_Results-${params.day}"

profiles {
    standard { includeConfig 'conf/rockfish.config' }
    rockfish { includeConfig 'conf/rockfish.config' }

    // Test profile: single fixed architecture, fast local execution.
    // cv_maf and cv_ld are set explicitly (matching ms_maf/ms_ld in test_strains.txt) so that
    // the non-null cv_maf code path is exercised on every standard test run. The CV pool is
    // identical to the marker set pool — pipeline output is semantically unchanged.
    test {
        params {
            strainfile = "${projectDir}/data/test/test_strains.txt"
            // vcf removed — embedded in strainfile vcf column
            // maf removed — embedded in strainfile ms_maf column
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
            cv_maf     = 0.05   // matches ms_maf in test_strains.txt → identical CV pool
            cv_ld      = 0.8    // matches ms_ld in test_strains.txt → same LD pruning
        }
    }

    // Docker profile: run locally with containerized tools
    docker { includeConfig 'conf/docker.config' }

    // Test profile: variable architecture grid for broader coverage
    test_variable {
        params {
            strainfile = "${projectDir}/data/test/test_strains.txt"
            // vcf removed — embedded in strainfile vcf column
            // maf removed — embedded in strainfile ms_maf column
            nqtl       = "${projectDir}/data/test/variable_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/variable_architecture/h2.csv"
            effect     = "${projectDir}/data/test/variable_architecture/effect_sizes.csv"
            reps       = 2
        }
    }

    // Test profile: CV pool broader than marker SNP set (cv_maf < ms_maf).
    // Exercises the non-marker causal variant path end-to-end.
    // Run: nextflow run main.nf -profile test_cv_pool
    test_cv_pool {
        params {
            strainfile = "${projectDir}/data/test/test_strains.txt"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
            cv_maf     = 0.01   // < ms_maf (0.05 in strainfile) → broader CV pool
            cv_ld      = 0.99   // > ms_ld (0.8 in strainfile) → less LD pruning
        }
    }

    // Test profile: 3-species (c_elegans, c_briggsae, c_tropicalis) — exercises mixed-species path.
    // Requires running data/test/generate_test_{cb,ct}_vcf.sh first to produce the test VCFs.
    // Stub-run works without VCF files: nextflow run . -profile test_three_species -stub-run
    test_three_species {
        params {
            strainfile = "${projectDir}/data/test/test_strains_three_species.txt"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
        }
    }

    // HPC profile: single fixed architecture, full VCF on Rockfish.
    // Requires running data/test/generate_hpc_strainfile.sh on Rockfish first.
    // Run: nextflow run main.nf -profile test_hpc,rockfish --legacy_assess
    test_hpc {
        params {
            strainfile = "${projectDir}/data/test/hpc_strains.txt"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
            cv_maf     = 0.05   // matches ms_maf in hpc_strains.txt → identical CV pool
            cv_ld      = 0.8    // matches ms_ld in hpc_strains.txt → same LD pruning
        }
    }

    // HPC profile: variable architecture grid, full VCF on Rockfish.
    // Run: nextflow run main.nf -profile test_hpc_variable,rockfish --legacy_assess
    test_hpc_variable {
        params {
            strainfile = "${projectDir}/data/test/hpc_strains.txt"
            nqtl       = "${projectDir}/data/test/variable_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/variable_architecture/h2.csv"
            effect     = "${projectDir}/data/test/variable_architecture/effect_sizes.csv"
            reps       = 2
        }
    }

    // HPC profile: CV pool broader than marker set, full VCF on Rockfish.
    // --legacy_assess is incompatible with non-marker causal variants; omit it.
    // Run: nextflow run main.nf -profile test_hpc_cv_pool,rockfish
    test_hpc_cv_pool {
        params {
            strainfile = "${projectDir}/data/test/hpc_strains.txt"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
            cv_maf     = 0.01   // < ms_maf (0.05 in strainfile) → broader CV pool
            cv_ld      = 0.99   // > ms_ld (0.8 in strainfile) → less LD pruning
        }
    }

    // HPC profile: 3-species (c_elegans, c_briggsae, c_tropicalis), full VCFs on Rockfish.
    // Requires running data/test/generate_hpc_strainfile.sh with all three VCF paths.
    // Run: nextflow run main.nf -profile test_hpc_three_species,rockfish --legacy_assess
    test_hpc_three_species {
        params {
            strainfile = "${projectDir}/data/test/hpc_strains_three_species.txt"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
        }
    }
}

process {
    withName: 'PLINK_RECODE_MS_VCF' {
        ext.tag = { "${meta.id}_MS" }
    }
    withName: 'PLINK_RECODE_CV_VCF' {
        ext.tag = { "${meta.id}_CV" }
    }
}

timeline {
    enabled = true
    file = "${outputDir}/pipeline-info/${params.timestamp}_timeline.html"
}

report {
    enabled = true
    file = "${outputDir}/pipeline-info/${params.timestamp}_report.html"
}

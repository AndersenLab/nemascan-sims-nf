import java.time.*
Date now = new Date()

// Require NF 24.10.x — the publish: block uses nextflow.preview.output
// which is a preview feature in 24.x (deprecated in 25.10+, absent in <24.04)
// Use manifest.nextflowVersion for declarative version guard
manifest {
    nextflowVersion = '>=24.10.0,<25.0.0'
}

nextflow.enable.moduleBinaries = true
process.cache = "lenient"

params {
    day = now.format("yyyMMdd")
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
    tracedir = "pipeline-info"
    debug = false
    help = false

    strainfile = null
    sparse_cut = 0.05
    group_qtl  = 1000
    ci_size    = 150
    maf        = null
    nqtl       = null
    reps       = 2
    h2         = null
    effect     = null
    qtlloc     = null
    sthresh    = "BF"
    mito_name  = null
    simulate_qtlloc = null

    // Database integration — always writes Parquet DB alongside simulation results.
    // Default null: resolved at runtime in main.nf using workflow.outputDir
    db_output = null

    // DB-path QTL analysis — opt-in. When true, queries the populated DB to
    // detect QTL intervals and assess against simulated truth, producing
    // db_simulation_assessment_results.tsv alongside the existing output.
    analyze_db = false

    //
}

outputDir = "Analysis_Results-${params.day}"

profiles {
    standard { includeConfig 'conf/rockfish.config' }
    rockfish { includeConfig 'conf/rockfish.config' }

    // Test profile: single fixed architecture, fast local execution
    test {
        process.executor = 'local'
        params {
            vcf        = "${projectDir}/data/test/test.vcf.gz"
            strainfile = "${projectDir}/data/test/test_strains.txt"
            maf        = "${projectDir}/data/test/test_maf.csv"
            nqtl       = "${projectDir}/data/test/fixed_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/fixed_architecture/h2.csv"
            effect     = "${projectDir}/data/test/fixed_architecture/effect_sizes.csv"
            reps       = 1
        }
    }

    // Docker profile: run locally with containerized tools
    docker { includeConfig 'conf/docker.config' }

    // Test profile: variable architecture grid for broader coverage
    test_variable {
        process.executor = 'local'
        params {
            vcf        = "${projectDir}/data/test/test.vcf.gz"
            strainfile = "${projectDir}/data/test/test_strains.txt"
            maf        = "${projectDir}/data/test/test_maf.csv"
            nqtl       = "${projectDir}/data/test/variable_architecture/nqtl.csv"
            h2         = "${projectDir}/data/test/variable_architecture/h2.csv"
            effect     = "${projectDir}/data/test/variable_architecture/effect_sizes.csv"
            reps       = 2
        }
    }
}

timeline {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_timeline.html"
}

report {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_report.html"
}

/*
    Rockfish Configuration
*/

if (params.output_dir == null) {
    System.err.println "ERROR: rockfish profile requires --output_dir so the failures directory is on a persistent path"
    System.exit(1)
}
if (!params.output_dir.startsWith('/')) {
    System.err.println "ERROR: rockfish profile requires --output_dir to be an absolute path (got: '${params.output_dir}'). Use /vast/eande106/... or similar."
    System.exit(1)
}

process {
    executor = "slurm"
    clusterOptions = "-A eande106 -e errlog.txt -N 1"
    time = "1.hour"
    cpus = 1
    memory = "4G"
    partition = "parallel"

    withName: 'LOCAL_.*' {
        executor = 'local'
        container = null
    }
    withName: 'BCFTOOLS_.*' {
        container = "docker://quay.io/biocontainers/bcftools:1.16--hfe4b78e_1"
    }
    withName: 'PLINK_.*' {
        container = "docker://andersenlab/plink:1.9"
    }
    withName: 'GCTA_.*' {
        container = "docker://quay.io/biocontainers/gcta:1.94.1--h9ee0642_0"
    }
    withName: 'R_.*' {
        container = "docker://andersenlab/r_packages:20250519"
    }
    withName: 'PYTHON_.*' {
        container = "docker://andersenlab/numpy-20250506"
    }
    withName: 'DB_MIGRATION_.*' {
        container = "docker://andersenlab/migrate-sims:20260202"
    }

    // first three processes were prev all one processes `prepare_simulation_files`
    withLabel: bcftools_rename_chroms {
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
        maxRetries = 3
    }
    withLabel: bcftools_extract_strains {
        time = "1.hour"
        cpus = 4
        memory = "40G"
        array = 100
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
        maxRetries = 3
    }
    withLabel: bcftools_create_genotype_matrix {
        time = "1.hour"
        cpus = 4
        memory = "40G"
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
        maxRetries = 3
        array = 100
    }
    withLabel: plink_recode_vcf {
        time = "1.hour"
        cpus = 4
        memory = "40G"
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
        maxRetries = 3
        array = 100
    }

    // previous process `chrom_eigen_variants_sims`
    withLabel: r_find_genotype_matrix_eigen {
        time = "30.minute"
        cpus = 2
        memory = "60G"
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
        maxRetries = 3
        array = 100
    }

    // previous all `simulate_map_phenotypes` processes
    withLabel: gcta_simulate_phenotypes {
        time = "10.minute"
        cpus = 1          // --simu-qt pinned to thread-num 1 for numerical determinism
        memory = "20G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: plink_update_by_h2 {
        time = "10.minute"
        cpus = 4
        memory = "20G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: gcta_make_grm {
        time   = { 10.minute * task.attempt }
        memory = { 20.GB * Math.pow(1.5, task.attempt - 1) }
        cpus = 1  // all GCTA ops pinned to thread-num 1 for numerical determinism
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: gcta_perform_gwa {
        time   = { 10.minute * task.attempt }
        memory = { 20.GB * Math.pow(1.5, task.attempt - 1) }
        cpus = 4
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }

    // pre-fanout CV-pool resolve: terminate on retry exhaustion (cone-level,
    // not rep-level); stub runs always retry. array sizing non-critical here.
    withLabel: python_filter_cv_pool_resolve {
        time = "10.minute"
        cpus = 1
        memory = "2G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 2 ? 'retry' : 'terminate') }
        maxRetries = 2
        array = 100
    }

    // both were previously run locally so opt. for default
    withLabel: python_simulate_effects_global {
        time = "10.minute"
        cpus = 1
        memory = "2G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 2 ? 'retry' : 'ignore') }
        maxRetries = 2
        array = 100
    }
    withLabel: r_simulate_effects_global {
        time = "10.minute"
        cpus = 1
        memory = "2G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: r_simulate_effects_local {
        time = "10.minute"
        cpus = 1
        memory = "2G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }

    // previous process `get_gcta_intervals`
    withLabel: r_get_gcta_intervals {
        clusterOptions = '-A eande106_bigmem -e errlog.txt -N 1 -p bigmem'
        time   = { 4.hour * task.attempt }
        memory = { 20.GB * Math.pow(1.5, task.attempt - 1) }
        cpus = 1
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 5 ? 'retry' : 'ignore') }
        maxRetries = 5
        array = 100
    }

    // also can be run locally so opt. for default
    withLabel: r_assess_sims {
        time = "20.minute"
        cpus = 1
        memory = "20G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    // Database migration processes (Phase 1+)
    withLabel: db_migration_write_marker_set {
        time = "30.minute"
        cpus = 2
        memory = "8G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: db_migration_write_gwa_to_db {
        time   = { 10.minute * task.attempt }
        memory = { 4.GB * Math.pow(1.5, task.attempt - 1) }
        cpus = 1
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: db_migration_aggregate_metadata {
        time = "10.minute"
        cpus = 1
        memory = "4G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 2 ? 'retry' : 'ignore') }
        maxRetries = 2
    }
    withLabel: db_migration_analyze_qtl {
        time = "20.minute"
        cpus = 1
        memory = "8G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: db_migration_assess_sims {
        time = "20.minute"
        cpus = 1
        memory = "8G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: db_migration_write_genotype_matrix {
        time = "10.minute"
        cpus = 1
        memory = "8G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
    }
    withLabel: db_migration_write_trait_data {
        time = "5.minute"
        cpus = 1
        memory = "2G"
        errorStrategy = { workflow.stubRun ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
        maxRetries = 3
        array = 100
    }
    withLabel: r_validate_replication {
        container  = "docker://andersenlab/migrate-sims:20260202"
        time       = "15.minute"
        cpus       = 1
        memory     = "8G"
        errorStrategy = 'terminate'
    }
    withLabel: db_migration_cleanup {
        container  = "docker://andersenlab/migrate-sims:20260202"
        time       = "10.minute"
        cpus       = 1
        memory     = "4G"
        errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'terminate' }
        maxRetries = 3
    }
}

executor {
    queueSize = 100
    submitRateLimit = 10
}

params {
    baseDir       = '/vast/eande106'
    workDir       = '/vast/eande106/work'
    dataDir       = '/vast/eande106/data'
    softwareDir   = '/data/eande106/software'
    slurm_account = 'eande106'           // SLURM account; override with --slurm_account
    scratch_dir   = '/scratch4/eande106' // Nextflow work dir on scratch; override with --scratch_dir
}

singularity {
    enabled = true
    autoMounts = true
    runOptions = "--bind ${projectDir} --bind ${params.output_dir}"
    cacheDir = "${params.baseDir}/singularity"
}

workflow {
    workDir = params.scratch_dir
}
